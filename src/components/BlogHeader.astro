---
import { Separator } from "$lib/components/ui/separator";
import { Badge } from "$lib/components/ui/badge/index.js";
const { frontmatter } = Astro.props;
---
<div class="bg-light-accent"> 
    <Separator class="bg-black" />
    <div class="p-5">
      <p class="text-5xl pt-5 pb-2">{frontmatter.title}</p>
      <p class="font-light pb-3">{frontmatter.description}</p>
      <div class="flex items-center space-x-6">
        <p class="text-xs flex-initial place-self-center font-mono pt-3"><span class="font-semibold">PUBLISHED: </span>{frontmatter.pubDate.toString().slice(3,10)},{frontmatter.pubDate.toString().slice(10,15)}</p>
        <Separator orientation="vertical" class="bg-black h-4"/>
        <div class="flex flex-wrap">
          {frontmatter.tags.map((tag: unknown) => (
            <a href={`/tags/${tag}`} class="text-black"><Badge class='font-normal bg-accent-color transition duration-[400ms] hover:bg-dark-accent' variant="secondary">{tag}</Badge></a>
            <Separator orientation="vertical" class="w-1.5"/>
          ))}
        </div>
      </div>
    </div>
    <Separator class="bg-black" />
  </div>
  <Separator class="h-8" />